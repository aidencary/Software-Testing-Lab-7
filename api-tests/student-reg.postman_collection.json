{
  "info": {
    "name": "StudentRegDemo API Tests",
    "description": "API-level tests for the StudentRegDemo Spring Boot backend. Run via Newman in CI (see .github/workflows/api-tests.yml) or locally against a backend booted on http://localhost:8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "GET /api/courses - list is reachable",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/courses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('body is a JSON array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/courses - valid payload is accepted",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CSCE 3513\",\n  \"instructor\": 42,\n  \"maxSize\": 30,\n  \"room\": \"JBHT 216\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/courses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('response confirms the course was added', function () {",
              "    pm.expect(pm.response.text()).to.include('added successfully');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/courses - maxSize=0 is rejected with 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bad Course\",\n  \"instructor\": 1,\n  \"maxSize\": 0,\n  \"room\": \"Nowhere\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/courses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 400 (validator rejects maxSize < 1)', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('error body mentions maxSize', function () {",
              "    pm.expect(pm.response.text().toLowerCase()).to.include('maxsize');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/students - valid payload is accepted",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ada Lovelace\",\n  \"major\": \"Computer Science\",\n  \"gpa\": 4.0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('response confirms the student was added', function () {",
              "    pm.expect(pm.response.json().message).to.include('added successfully');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/students - GPA > 4.0 is rejected with 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Over-Achiever\",\n  \"major\": \"CS\",\n  \"gpa\": 5.0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students",
          "host": ["{{baseUrl}}"],
          "path": ["api", "students"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 400 (GPA cap is 4.0)', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('error body mentions gpa', function () {",
              "    pm.expect(pm.response.text().toLowerCase()).to.include('gpa');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
